# Finance Visualizer Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Password for the app login page.
# Provide EITHER PASSWORD (plaintext, hashed at startup) OR PASSWORD_HASH (pre-hashed bcrypt).
# To generate a bcrypt hash: htpasswd -bnBC 12 "" yourpassword | tr -d ':\n'
PASSWORD=
PASSWORD_HASH=

# Secret key for signing JWT authentication tokens.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Port the backend HTTP server listens on.
PORT=8080

# Path to the SQLite database file.
# In Docker, mount a named volume to /data and set: DB_PATH=/data/finance.db
DB_PATH=data/finance.db
